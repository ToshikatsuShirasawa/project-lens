// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// プロジェクト内の権限。MEMBER=閲覧・タスク。ADMIN/OWNER=メンバー・列・基本設定の管理
enum ProjectMemberRole {
  OWNER
  ADMIN
  MEMBER
}

/// プロジェクト単位のメール招待（`project_invitations`）
enum ProjectInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

/// 企業 / ワークスペースに対する所属（企業管理・課金の枠）
enum OrganizationMemberRole {
  OWNER
  ADMIN
  MEMBER
}

/// タスクの優先度（シンプルな3段階）
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

/// AIタスク候補に対するユーザー操作ログ（分析・精度改善用）
enum AiTaskCandidateEventType {
  SHOWN
  ACCEPTED
  SNOOZED
  DISMISSED
}

model User {
  /// Supabase Auth `auth.users.id`（UUID）と1対1
  id        String   @id
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         ProjectMember[]
  organizationMembers OrganizationMember[]
  assignedTasks            KanbanTask[]
  projectInvitationsSent   ProjectInvitation[] @relation("ProjectInvitationInvitedBy")

  @@map("users")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  /// このワークスペース内で作成可能な `projects` 数の上限。`null` はプラン等で定めない限り無制限
  projectLimit Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            OrganizationMember[]
  projects           Project[]
  projectInvitations ProjectInvitation[]

  @@map("organizations")
}

/// 企業内所属。`project_members` とは別スコープ
model OrganizationMember {
  id        String                 @id @default(cuid())
  role      OrganizationMemberRole @default(MEMBER)
  createdAt DateTime               @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  members                 ProjectMember[]
  tasks                   KanbanTask[]
  kanbanColumns           ProjectKanbanColumn[]
  invitations             ProjectInvitation[]
  aiTaskCandidateEvents   AiTaskCandidateEvent[]
  workReports             WorkReport[]

  @@index([organizationId])
  @@map("projects")
}

/// プロジェクトへのメール招待（トークン URL で受け入れ）
model ProjectInvitation {
  id     String @id @default(cuid())
  /// 不変: 重複 PENDING 判定と将来の再送に利用
  email  String
  /// `project_members.role` と同じ想定
  role   ProjectMemberRole

  token  String                 @unique
  status ProjectInvitationStatus  @default(PENDING)
  /// 採用時にこの時刻を過ぎていれば受け入れ不可（バッチ無しの最小版）
  expiresAt  DateTime
  acceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  invitedByUserId String
  invitedByUser   User   @relation("ProjectInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@index([projectId, status])
  @@index([projectId, email])
  @@index([email])
  @@index([organizationId])
  @@map("project_invitations")
}

/// プロジェクトごとのカンバン列（表示名・並びはプロジェクト単位で変更可能にする前提）
model ProjectKanbanColumn {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 安定キー（backlog 等）。テンプレート切替や API 入力の基点
  key       String
  name      String
  sortOrder Int      @default(0)

  colorKey   String?
  columnType String?
  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks KanbanTask[] @relation("TaskKanbanColumn")

  @@unique([projectId, key])
  @@index([projectId, sortOrder])
  @@map("project_kanban_columns")
}

model ProjectMember {
  id        String            @id @default(cuid())
  /// 上記 `ProjectMemberRole`（API の `isProjectManagerRole` は ADMIN/OWNER）
  role      ProjectMemberRole @default(MEMBER)
  createdAt DateTime          @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model KanbanTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  /// 日付単位。時刻は未使用想定（UTC 00:00 で格納）
  dueDate     DateTime?
  /// 未設定可。既存行は null のまま
  priority    TaskPriority?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  columnId     String
  kanbanColumn ProjectKanbanColumn @relation("TaskKanbanColumn", fields: [columnId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([projectId, columnId, sortOrder])
  @@index([projectId, dueDate])
  @@map("kanban_tasks")
}

/// 作業日報。プロジェクトメンバーが日々の進捗・ブロッカーを記録し AI 候補生成の素材にする
model WorkReport {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 投稿者の User.id（未ログイン投稿や将来の匿名投稿は null 許容）
  submittedByUserId String?
  /// 表示用の投稿者名（User.name / email から設定）
  submittedBy       String

  completed   String @default("")
  inProgress  String @default("")
  blockers    String @default("")
  nextActions String @default("")

  /// 報告対象日（省略時は作成日時）
  reportDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, reportDate])
  @@map("work_reports")
}

/// AI候補の表示・承認・あとで・却下の最小ログ（クライアント送信・失敗時もUIは継続）
model AiTaskCandidateEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  candidateId String

  eventType AiTaskCandidateEventType

  candidateTitle          String
  /// UI / 集計用のソース表現（例: slack, Slack ラベルはクライアント任せ）
  candidateSource         String
  confidenceLevel           String
  recommendationReason    String?
  structuredReasonsJson     Json

  /// サーバーで作成されたタスク ID（クライアントのみの場合は null）
  createdTaskId String?

  userId         String
  organizationId String

  metadataJson Json?

  @@index([projectId, eventType, createdAt])
  @@index([projectId, createdAt])
  @@index([organizationId, createdAt])
  @@map("ai_task_candidate_events")
}

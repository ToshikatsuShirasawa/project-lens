// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ProjectMemberRole {
  OWNER
  ADMIN
  MEMBER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   ProjectMember[]
  assignedTasks KanbanTask[]

  @@map("users")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members        ProjectMember[]
  tasks          KanbanTask[]
  kanbanColumns  ProjectKanbanColumn[]

  @@map("projects")
}

/// プロジェクトごとのカンバン列（表示名・並びはプロジェクト単位で変更可能にする前提）
model ProjectKanbanColumn {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 安定キー（backlog 等）。テンプレート切替や API 入力の基点
  key       String
  name      String
  sortOrder Int      @default(0)

  colorKey   String?
  columnType String?
  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks KanbanTask[] @relation("TaskKanbanColumn")

  @@unique([projectId, key])
  @@index([projectId, sortOrder])
  @@map("project_kanban_columns")
}

model ProjectMember {
  id        String            @id @default(cuid())
  role      ProjectMemberRole @default(MEMBER)
  createdAt DateTime          @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model KanbanTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  columnId     String
  kanbanColumn ProjectKanbanColumn @relation("TaskKanbanColumn", fields: [columnId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([projectId, columnId, sortOrder])
  @@map("kanban_tasks")
}

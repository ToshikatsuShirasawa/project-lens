// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// プロジェクト内の権限。MEMBER=閲覧・タスク。ADMIN/OWNER=メンバー・列・基本設定の管理
enum ProjectMemberRole {
  OWNER
  ADMIN
  MEMBER
}

/// プロジェクト単位のメール招待（`project_invitations`）
enum ProjectInvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

/// 企業 / ワークスペースに対する所属（企業管理・課金の枠）
enum OrganizationMemberRole {
  OWNER
  ADMIN
  MEMBER
}

/// タスクの優先度（シンプルな3段階）
enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

/// AIタスク候補に対するユーザー操作ログ（分析・精度改善用）
enum AiTaskCandidateEventType {
  SHOWN
  ACCEPTED
  SNOOZED
  DISMISSED
}

/// AIタスク候補の現在状態（行なし＝OPEN/未判断）
enum AiTaskCandidateStatus {
  HELD
  DISMISSED
  ADDED
}

/// AIタスク候補の生成ソース（SLACK / MEETING は将来拡張用）
enum AiTaskCandidateSource {
  WORK_REPORT
  SLACK
  MEETING
  MEMO
}

/// 未整理テキスト入力の種類。Slack API 連携前の手動入力もこの区分で保存する
enum ProjectInputType {
  SLACK
  MEETING
  MEMO
}

/// Slack手動取り込みの期間プリセット
enum SlackImportRangePreset {
  LAST_24_HOURS
  LAST_3_DAYS
  LAST_7_DAYS
}

/// Slack取り込み処理の状態
enum SlackImportStatus {
  RUNNING
  SUCCESS
  FAILED
}

model User {
  /// Supabase Auth `auth.users.id`（UUID）と1対1
  id        String   @id
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships         ProjectMember[]
  organizationMembers OrganizationMember[]
  assignedTasks            KanbanTask[]
  projectInvitationsSent   ProjectInvitation[]       @relation("ProjectInvitationInvitedBy")
  updatedAiTaskCandidateStates AiTaskCandidateState[]
  slackConnectionsInstalled SlackConnection[]         @relation("SlackConnectionInstalledBy")
  slackImports              SlackImport[]             @relation("SlackImportImportedBy")

  @@map("users")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  /// このワークスペース内で作成可能な `projects` 数の上限。`null` はプラン等で定めない限り無制限
  projectLimit Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            OrganizationMember[]
  projects           Project[]
  projectInvitations ProjectInvitation[]
  slackConnections   SlackConnection[]

  @@map("organizations")
}

/// 企業内所属。`project_members` とは別スコープ
model OrganizationMember {
  id        String                 @id @default(cuid())
  role      OrganizationMemberRole @default(MEMBER)
  createdAt DateTime               @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  members                 ProjectMember[]
  tasks                   KanbanTask[]
  kanbanColumns           ProjectKanbanColumn[]
  invitations             ProjectInvitation[]
  aiTaskCandidateEvents   AiTaskCandidateEvent[]
  aiTaskCandidateStates   AiTaskCandidateState[]
  workReports             WorkReport[]
  inputs                  ProjectInput[]
  slackImports            SlackImport[]
  slackMessages           SlackMessage[]

  @@index([organizationId])
  @@map("projects")
}

/// プロジェクトへのメール招待（トークン URL で受け入れ）
model ProjectInvitation {
  id     String @id @default(cuid())
  /// 不変: 重複 PENDING 判定と将来の再送に利用
  email  String
  /// `project_members.role` と同じ想定
  role   ProjectMemberRole

  token  String                 @unique
  status ProjectInvitationStatus  @default(PENDING)
  /// 採用時にこの時刻を過ぎていれば受け入れ不可（バッチ無しの最小版）
  expiresAt  DateTime
  acceptedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  invitedByUserId String
  invitedByUser   User   @relation("ProjectInvitationInvitedBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)

  @@index([projectId, status])
  @@index([projectId, email])
  @@index([email])
  @@index([organizationId])
  @@map("project_invitations")
}

/// プロジェクトごとのカンバン列（表示名・並びはプロジェクト単位で変更可能にする前提）
model ProjectKanbanColumn {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 安定キー（backlog 等）。テンプレート切替や API 入力の基点
  key       String
  name      String
  sortOrder Int      @default(0)

  colorKey   String?
  columnType String?
  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks KanbanTask[] @relation("TaskKanbanColumn")

  @@unique([projectId, key])
  @@index([projectId, sortOrder])
  @@map("project_kanban_columns")
}

model ProjectMember {
  id        String            @id @default(cuid())
  /// 上記 `ProjectMemberRole`（API の `isProjectManagerRole` は ADMIN/OWNER）
  role      ProjectMemberRole @default(MEMBER)
  createdAt DateTime          @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

model KanbanTask {
  id          String   @id @default(cuid())
  title       String
  description String?
  /// 日付単位。時刻は未使用想定（UTC 00:00 で格納）
  dueDate     DateTime?
  /// 未設定可。既存行は null のまま
  priority    TaskPriority?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  columnId     String
  kanbanColumn ProjectKanbanColumn @relation("TaskKanbanColumn", fields: [columnId], references: [id], onDelete: Cascade)

  assigneeId String?
  assignee   User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  aiTaskCandidateStates AiTaskCandidateState[]

  @@index([projectId, columnId, sortOrder])
  @@index([projectId, dueDate])
  @@map("kanban_tasks")
}

/// 作業日報。プロジェクトメンバーが日々の進捗・ブロッカーを記録し AI 候補生成の素材にする
model WorkReport {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 投稿者の User.id（未ログイン投稿や将来の匿名投稿は null 許容）
  submittedByUserId String?
  /// 表示用の投稿者名（User.name / email から設定）
  submittedBy       String

  completed   String @default("")
  inProgress  String @default("")
  blockers    String @default("")
  nextActions String @default("")

  /// 報告対象日（省略時は作成日時）
  reportDate DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  aiTaskCandidateStates AiTaskCandidateState[]

  @@index([projectId])
  @@index([projectId, reportDate])
  @@map("work_reports")
}

/// Slackログ・議事録・自由メモなどの未整理テキスト。AI候補生成の素材にする
model ProjectInput {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)

  inputType ProjectInputType @default(MEETING)
  title     String?
  body      String
  sourceLabel String?

  /// 投稿者の User.id（将来の外部連携や匿名入力は null 許容）
  submittedByUserId String?
  /// 表示用の投稿者名（手動指定があればそれを優先）
  submittedBy       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slackImport SlackImport?

  @@index([projectId, createdAt])
  @@map("project_inputs")
}

/// Slack workspace接続情報。Bot token は暗号化済み文字列のみ保存する
model SlackConnection {
  id                String   @id @default(cuid())
  organizationId    String
  teamId            String
  teamName          String
  botUserId         String?
  botTokenEncrypted String
  installedByUserId String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  installedByUser User         @relation("SlackConnectionInstalledBy", fields: [installedByUserId], references: [id], onDelete: Restrict)
  imports         SlackImport[]
  messages        SlackMessage[]

  @@unique([organizationId, teamId])
  @@index([organizationId])
  @@map("slack_connections")
}

/// project単位のSlack手動取り込み履歴
model SlackImport {
  id               String                 @id @default(cuid())
  projectId        String
  connectionId     String
  channelId        String
  channelName      String
  rangePreset      SlackImportRangePreset
  oldestTs         String
  latestTs         String
  messageCount     Int                    @default(0)
  status           SlackImportStatus      @default(RUNNING)
  errorMessage     String?
  projectInputId   String?                @unique
  importedByUserId String
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  project        Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  connection     SlackConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  projectInput   ProjectInput?   @relation(fields: [projectInputId], references: [id], onDelete: SetNull)
  importedByUser User            @relation("SlackImportImportedBy", fields: [importedByUserId], references: [id], onDelete: Restrict)
  messages       SlackMessage[]

  @@index([projectId, createdAt])
  @@index([connectionId, channelId])
  @@map("slack_imports")
}

/// Slackメッセージ単位の保存。messageTsで重複取り込みを防ぐ
model SlackMessage {
  id           String   @id @default(cuid())
  connectionId String
  projectId    String
  importId     String
  channelId    String
  channelName  String
  messageTs    String
  threadTs     String?
  userId       String?
  userName     String?
  text         String
  permalink    String?
  createdAt    DateTime @default(now())

  connection SlackConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  project    Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  import     SlackImport     @relation(fields: [importId], references: [id], onDelete: Cascade)

  @@unique([connectionId, channelId, messageTs])
  @@index([projectId, channelId, messageTs])
  @@index([importId])
  @@map("slack_messages")
}

/// AI候補の表示・承認・あとで・却下の最小ログ（クライアント送信・失敗時もUIは継続）
model AiTaskCandidateEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  candidateId String

  eventType AiTaskCandidateEventType

  candidateTitle          String
  /// UI / 集計用のソース表現（例: slack, Slack ラベルはクライアント任せ）
  candidateSource         String
  confidenceLevel           String
  recommendationReason    String?
  structuredReasonsJson     Json

  /// サーバーで作成されたタスク ID（クライアントのみの場合は null）
  createdTaskId String?

  userId         String
  organizationId String

  metadataJson Json?

  @@index([projectId, eventType, createdAt])
  @@index([projectId, createdAt])
  @@index([organizationId, createdAt])
  @@map("ai_task_candidate_events")
}

/// AIタスク候補の現在状態（行なし＝OPEN/未判断。score/reason は保存しない）
model AiTaskCandidateState {
  id              String                @id @default(cuid())
  projectId       String
  candidateKey    String
  candidateTitle  String
  status          AiTaskCandidateStatus
  sourceType      AiTaskCandidateSource @default(WORK_REPORT)
  sourceReportId  String?
  createdTaskId   String?
  updatedByUserId String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceReport  WorkReport? @relation(fields: [sourceReportId], references: [id], onDelete: SetNull)
  createdTask   KanbanTask? @relation(fields: [createdTaskId], references: [id], onDelete: SetNull)
  updatedByUser User?       @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([projectId, candidateKey])
  @@index([projectId, status])
  @@index([sourceReportId])
  @@index([createdTaskId])
  @@map("ai_task_candidate_states")
}
